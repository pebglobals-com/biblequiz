{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bible-quiz-guide",
  "main": ".next/worker.js",
  "compatibility_date": "2026-07-01",
  "pages_build_output_dir": ".vercel/output",

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bible-quiz-db",
      "database_id": ""
    }
  ],

  "env": {
    "OPENCODE_API_KEY": ""
  }
}
